# JIRA Configuration
# NOTE: per-project JIRA credentials are now stored per project (Settings panel);
# these globals are only used by the legacy env-based assigned-stories sync.
JIRA_SITE_URL=https://your-jira-instance.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEYS=TEAM

# Claude API — powers the AI-assisted import "break down into subtasks" feature.
ANTHROPIC_API_KEY=your_anthropic_api_key
# Optional: override the model used to break stories into subtasks.
ANTHROPIC_BREAKDOWN_MODEL=claude-sonnet-5

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kanban

# Environment
NODE_ENV=development

# GitHub token for PR-gated completion (repo read scope). One token serves all
# repos listed in each project's "GitHub repositories" setting.
GITHUB_TOKEN=
