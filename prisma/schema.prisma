// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                   String   @id @default(cuid())
  name                 String
  type                 String   @default("STANDALONE")
  jiraProjectKey       String?
  jiraSiteUrl          String?
  jiraEmail            String?
  jiraApiToken         String?
  githubRepos          String?
  jiraSyncStatuses     String?  @default("To Do, In Progress, Code Revew, Code Review")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  stories   Story[]
  workUnits WorkUnit[] @relation("ProjectWorkUnits")

  @@index([jiraProjectKey])
}

model Story {
  id                        String     @id @default(cuid())
  jiraKey                   String     @unique
  jiraId                    String     @unique
  projectKey                String
  summary                   String
  description               String?
  jiraStatus                String
  epicKey                   String?
  epicName                  String?
  url                       String
  lastSyncedAt              DateTime
  completionCommentPostedAt DateTime?
  reopenCount               Int       @default(0) // times jiraStatus regressed to an earlier workflow stage (Equilibrium Meter churn signal)
  lastReopenedAt            DateTime?
  linkedFollowUpKeys        String?   // comma-separated JIRA keys of issues linking back to this story, first observed after it shipped
  lastLinkedFollowUpAt      DateTime?
  projectId                 String?
  project                   Project?   @relation(fields: [projectId], references: [id])
  workUnits                 WorkUnit[]

  @@index([projectId])
}

model WorkUnit {
  id                      String    @id @default(cuid())
  storyId                 String
  story                   Story     @relation(fields: [storyId], references: [id])
  projectId               String?
  project                 Project?  @relation("ProjectWorkUnits", fields: [projectId], references: [id])
  title                   String
  description             String?
  acceptanceCriteria      String?
  verification            String?
  column                  String // "todo" | "in_progress" | "done"
  order                   Int
  subNumber               Int? // stable 1-based decomposition suffix (e.g. COM-540-1); null = not decomposed, Ponder-local only, never sent to JIRA
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt // drives the Equilibrium Meter's staleness axis
  completedAt             DateTime?
  archivedAt              DateTime?
  movedToQaReportedAt     DateTime?
  verificationRequestedAt DateTime?
  verifiedAt              DateTime?
  verificationOutcome     String?
  verificationSummary     String?
  reopenCount             Int       @default(0) // times moved backward through columns after advancing (Equilibrium Meter churn signal)
  lastReopenedAt          DateTime?

  workNotes   WorkNote[]
  attachments Attachment[]

  @@index([projectId])
  @@index([storyId])
}

model WorkNote {
  id         String   @id @default(cuid())
  workUnitId String
  workUnit   WorkUnit @relation(fields: [workUnitId], references: [id], onDelete: Cascade)
  body       String
  createdAt  DateTime @default(now())

  @@index([workUnitId])
}

model Attachment {
  id             String    @id @default(cuid())
  workUnitId     String
  workUnit       WorkUnit  @relation(fields: [workUnitId], references: [id], onDelete: Cascade)
  filename       String
  mimeType       String
  size           Int
  jiraUploadedAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([workUnitId])
}

model MeterSnapshot {
  id            String   @id @default(cuid())
  date          DateTime @unique // day granularity (UTC midnight)
  decomposition Int
  rigor         Int
  wip           Int
  staleness     Int
  churnEvents   Int
  overall       Int
  band          String   // "equilibrium" | "drifting" | "out"
  createdAt     DateTime @default(now())
}

model Badge {
  id       String   @id @default(cuid())
  key      String   @unique
  earnedAt DateTime @default(now())
}
